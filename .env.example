# 本地 Mock 调试（推荐，无需 Postgres）
USE_MOCK_DATA=true

# Database（USE_MOCK_DATA=false 且接真实库时使用）
# 本地 Docker：
# POSTGRES_URL=postgres://taskmanager:taskmanager@localhost:5433/taskmanager
#
# Vercel 若 Storage 锁死了 POSTGRES_URL（与别的项目共用 Neon），
# 新建独立 Neon 项目后，在 Vercel 手动添加此变量（可编辑）：
# TASKMANAGER_POSTGRES_URL=postgres://...@ep-xxx.neon.tech/neondb?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=taskmanager-local-dev-secret-change-in-production
